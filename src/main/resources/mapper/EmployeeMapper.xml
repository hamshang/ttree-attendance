<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.ttreeattendance.mapper.EmployeeMapper">

    <select id="findByLoginId"
            parameterType="String"
            resultType="com.example.ttreeattendance.dto.Employee">

        SELECT
            emp_id empId,
            login_id loginId,
            password,
            emp_name empName,
            dept_name deptName,
            position_name positionName
        FROM employee
        WHERE login_id = #{loginId}

    </select>

</mapper>